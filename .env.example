# Copy to .env (gitignored) and fill in. Documents the env vars the project needs.
# OpenRouteService free key: https://openrouteservice.org/sign-up/
ORS_API_KEY=

# LLM provider (OpenAI-compatible; provider-agnostic — swap these 3 to change provider).
#   Databricks-served Claude: LLM_BASE_URL=https://<workspace>/serving-endpoints, LLM_MODEL=databricks-claude-opus-4-8, no key (CLI auth)
#   OpenAI:                    LLM_BASE_URL=https://api.openai.com/v1,           LLM_MODEL=gpt-...,                  LLM_API_KEY=sk-...
#   Anthropic:                 LLM_BASE_URL=https://api.anthropic.com/v1,        LLM_MODEL=claude-opus-4-8,          LLM_API_KEY=sk-ant-...
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
